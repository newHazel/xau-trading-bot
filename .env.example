# Copy this file to .env and fill in your real values.
# NEVER put real secrets here — this template is committed to git.
# The real .env is git-ignored and stays only on your machine / server.

# --- Twelve Data (spot XAU/USD — free key at twelvedata.com) ---
TWELVE_DATA_API_KEY=your_twelvedata_api_key_here

# --- Bybit (OPTIONAL — public market data works without a key) ---
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# --- OANDA (optional — accurate spot XAU/USD via a free demo account) ---
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_ENVIRONMENT=practice

# --- Telegram (for live alerts) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Database ---
DB_PATH=data/database/trading_bot.sqlite

# --- General ---
ENV=development
LOG_LEVEL=INFO
